// Free function definitions + variable/array declarations + while/write/return

initArray(integer arr[], integer n) : void
  local
    integer i;
  do
    i = 0;
    while (i < n)
      do
        read(arr[i]);
        i = i + 1;
      end;
  end

sumArray(integer arr[], integer n) : integer
  local
    integer i;
    integer s;
  do
    i = 0;
    s = 0;
    while (i < n)
      do
        s = s + arr[i];
        i = i + 1;
      end;
    return (s);
  end

main
  local
    integer a[5];
    integer total;
  do
    initArray(a, 5);
    total = sumArray(a, 5);
    write(total);
  end
