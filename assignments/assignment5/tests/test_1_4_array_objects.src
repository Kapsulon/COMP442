// Test 1.4: Allocate memory for arrays of objects.
// Declares an array of Point objects; sets and reads member values.

class Point {
  public integer x;
  public integer y;
};

main
  local
    Point pts[3];
    integer i;
  do
    pts[0].x = 1;
    pts[0].y = 2;
    pts[1].x = 3;
    pts[1].y = 4;
    pts[2].x = 5;
    pts[2].y = 6;
    i = 0;
    while (i < 3)
      do
        write(pts[i].x);
        write(pts[i].y);
        i = i + 1;
      end;
  end
