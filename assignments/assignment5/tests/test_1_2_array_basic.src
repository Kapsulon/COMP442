// Test 1.2: Allocate memory for arrays of basic types.
// Declares integer array in main; stores and reads elements.

main
  local
    integer arr[4];
    integer i;
  do
    arr[0] = 10;
    arr[1] = 20;
    arr[2] = 30;
    arr[3] = 40;
    i = 0;
    while (i < 4)
      do
        write(arr[i]);
        i = i + 1;
      end;
  end
