// Test 5.2: Expression involving an array factor whose indexes are themselves expressions.
// Uses arithmetic expressions as array indices.

main
  local
    integer arr[6];
    integer i;
    integer j;
  do
    arr[0] = 100;
    arr[1] = 200;
    arr[2] = 300;
    arr[3] = 400;
    arr[4] = 500;
    arr[5] = 600;
    i = 1;
    j = 2;
    // index = i + j - 1 = 2
    write(arr[i + j - 1]);
    // index = j * 2 = 4
    write(arr[j * 2]);
    // index = (i + 1) * 2 - 1 = 3
    write(arr[(i + 1) * 2 - 1]);
  end
