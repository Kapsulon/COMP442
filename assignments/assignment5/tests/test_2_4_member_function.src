// Test 2.4: Call to member functions that can use their object's data members.
// Counter class whose increment() and get() methods access the private 'value' member.

class Counter {
  private integer value;
  public set(integer v) : void;
  public increment() : void;
  public get() : integer;
};

Counter::set(integer v) : void
  do
    value = v;
  end

Counter::increment() : void
  do
    value = value + 1;
  end

Counter::get() : integer
  do
    return (value);
  end

main
  local
    Counter c;
  do
    c.set(10);
    c.increment();
    c.increment();
    write(c.get());
  end
