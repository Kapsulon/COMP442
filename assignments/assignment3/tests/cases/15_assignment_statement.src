// Assignment statements: scalar, member access, array element, chained member

class NODE {
  public integer val;
  public integer next[2];
};

main
  local
    integer x;
    float f;
    NODE n;
    NODE arr[3];
    integer i;
  do
    x = 5;
    f = 2.5;
    n.val = x + 1;
    n.next[0] = 10;
    n.next[1] = n.next[0] + 1;
    i = 0;
    arr[i].val = i * 3;
    arr[i].next[0] = arr[i].val + x;
    x = n.next[0] + n.next[1];
    write(x);
    write(arr[0].val);
  end
